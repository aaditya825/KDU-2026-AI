PROJECT_NAME=FastAPI Production Template
PROJECT_DESCRIPTION=Reusable production-ready FastAPI starter template
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=127.0.0.1
PORT=8000
API_V1_PREFIX=/api/v1
EXPOSE_DOCS=true

LOG_LEVEL=INFO
LOG_JSON=false

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

SECRET_KEY=change-this-to-a-strong-random-secret-with-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_AUTH=5/minute

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/fastapi_app
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/fastapi_app_test
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true

POSTGRES_DB=fastapi_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Content Accessibility Suite - environment config
# Copy to .env and fill in your values.
# NEVER commit the real .env file.

# API keys.
# Supported cloud providers are Gemini and OpenAI only.
# Leave both blank to use the local fallback adapter.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Storage / database
DATA_DIR=data
SQLITE_DB_PATH=data/sqlite/cas.db

# Upload limits
MAX_UPLOAD_MB=25
MAX_AUDIO_DURATION_SEC=600
MAX_PDF_PAGES=200
MAX_IMAGE_PIXELS=40000000
MAX_QUERY_CHARS=1000
MAX_RETRIEVAL_TOP_K=20

# Default model choices.
# Do not use Groq/OpenRouter values here; those providers are not supported.
DEFAULT_VECTOR_STORE=chroma
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Primary small LLM default:
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash-lite

# OpenAI alternative:
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_MODEL=gpt-5-mini

DEFAULT_VISION_PROVIDER=ocr

# Audio is local. Supported values: faster_whisper, whisper.
# The concrete model size is centralized in app/config/model_registry.py.
DEFAULT_AUDIO_MODEL=faster_whisper

# Behaviour flags
LOCAL_ONLY=false
LOG_LEVEL=INFO
